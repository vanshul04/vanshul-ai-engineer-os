generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ApplicationStatus {
  SAVED
  APPLIED
  OA
  INTERVIEWING
  OFFER
  REJECTED
}

enum ProjectStatus {
  IDEA
  BUILDING
  SHIPPED
  PAUSED
}

model User {
  id             String            @id @default(cuid())
  name           String?
  email          String            @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  college        String?
  branch         String?
  graduationYear Int?
  targetRole     String            @default("AI Engineer")
  targetPackage  String?
  bio            String?
  githubUrl      String?
  linkedinUrl    String?
  xp             Int               @default(0)
  streak         Int               @default(0)
  readinessScore Int               @default(12)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  accounts       Account[]
  sessions       Session[]
  tasks          Task[]
  dsaProgress    DsaProgress[]
  roadmap        RoadmapProgress[]
  projects       Project[]
  studySessions  StudySession[]
  applications   Application[]
  notes          Note[]
  achievements   UserAchievement[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Task {
  id        String   @id @default(cuid())
  userId    String
  title     String
  category  String
  notes     String?
  xp        Int      @default(25)
  done      Boolean  @default(false)
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DsaProgress {
  id         String     @id @default(cuid())
  userId     String
  title      String
  topic      String
  difficulty Difficulty
  platform   String
  url        String?
  solvedAt   DateTime   @default(now())
  notes      String?
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RoadmapProgress {
  id             String   @id @default(cuid())
  userId         String
  module         String
  topic          String
  completed      Boolean  @default(false)
  completion     Int      @default(0)
  resourceUrl    String?
  difficulty     String   @default("Intermediate")
  estimatedHours Int      @default(4)
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module, topic])
}

model Project {
  id            String        @id @default(cuid())
  userId        String
  title         String
  description   String
  techStack     String[]
  githubUrl     String?
  deploymentUrl String?
  screenshotUrl String?
  completion    Int           @default(0)
  status        ProjectStatus @default(BUILDING)
  tasks         ProjectTask[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProjectTask {
  id        String  @id @default(cuid())
  projectId String
  title     String
  status    String  @default("todo")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model StudySession {
  id        String   @id @default(cuid())
  userId    String
  minutes   Int
  focusArea String
  notes     String?
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Application {
  id              String            @id @default(cuid())
  userId          String
  companyName     String
  role            String
  status          ApplicationStatus @default(SAVED)
  appliedDate     DateTime?
  interviewRounds Int               @default(0)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String
  folder    String   @default("General")
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String            @id @default(cuid())
  key         String            @unique
  title       String
  description String
  xpReward    Int               @default(100)
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}
